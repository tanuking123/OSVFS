# OSVFS configuration file (sample)
#
# Place this file as either:
#   * .\osvfs.toml                       (project-local; takes precedence)
#   * %APPDATA%\OSVFS\config.toml        (per-user, machine-global)
#
# Every key below mirrors a `--<flag>` option of the root `osvfs` command.
# CLI flags override the file per key, so you can keep stable defaults here
# and tweak individual options at the prompt. Both kebab-case
# (`root-folder`) and snake_case (`root_folder`) keys are accepted; kebab
# matches the CLI flag names and is preferred.
#
# All keys are optional. Uncomment and edit the ones you need.

# Object-store provider backing the virtualization root.
# Currently only "s3" is fully implemented; "gcs" / "azureblob" fail at startup.
# provider = "s3"

# Bucket (S3/GCS) or container (Azure) projected into the virtualization root.
# Required (here or on the CLI).
# bucket = "my-bucket"

# Local directory marked as the ProjFS virtualization root.
# Required (here or on the CLI).
# root-folder = "C:/Users/you/OSVFS"

# Optional endpoint override for S3-compatible servers (LocalStack, MinIO, ...).
# endpoint-url = "http://localhost:4566"

# AWS region. When omitted, the SDK falls back to the standard credential/region
# resolution chain (env vars, profile, IMDS).
# region = "ap-northeast-1"

# Optional key prefix within the bucket. When set, only objects under this
# prefix are projected into the virtualization root.
# prefix = "team-a/"

# Use credentials previously saved by `osvfs credentials set --profile <name>`
# (encrypted with DPAPI in Windows Credential Manager). Omit to use the AWS
# SDK's default chain.
# aws-profile = "prod"

# Polling interval (seconds) for detecting external object-store changes.
# 0 disables the watcher when change-source = "polling".
# sync-interval-seconds = 30

# Strategy for detecting external object-store changes.
#   "polling" (default) — re-list the bucket every sync-interval-seconds.
#   "events"            — long-poll an SQS queue carrying EventBridge S3
#                         notifications. Requires event-queue (below) and the
#                         server-side EventBridge rule + IAM policy described
#                         in the README.
# change-source = "polling"

# SQS queue URL or queue name carrying EventBridge S3 notifications.
# Required when change-source is "events".
# event-queue = "https://sqs.ap-northeast-1.amazonaws.com/123456789012/osvfs-changes"

# Polling reconciliation strategy. Only consulted when change-source = "polling".
#   "on-demand" (default) — re-list only the directories the user has visited
#                            via ProjFS. API cost scales with visited dirs, not
#                            bucket size. Matches the AWS S3 Files
#                            "metadata import on first access" model. External
#                            changes in unvisited subtrees are NOT propagated
#                            until the user enumerates them.
#   "full"               — re-list the entire bucket every sync-interval-seconds.
#                            Higher API cost but every key is reconciled.
# sync-mode = "on-demand"

# Upload bandwidth ceiling. Plain bytes/s by default; suffixes K/M/G mean
# KiB/s, MiB/s, GiB/s (e.g. "5M" = 5 MiB/s). Omit or set to "0" to disable.
# bandwidth-up = "5M"

# Download bandwidth ceiling. Same format as bandwidth-up.
# bandwidth-down = "10M"

# Stream size at or above which uploads are routed through the multipart path.
# Same K/M/G suffixes as bandwidth-up. Defaults to "8M". Raise it on fat links
# where a single PUT outperforms multipart's per-request overhead, lower it
# when most files are small but you still want multipart's parallel parts.
# multipart-threshold = "8M"

# Per-part size used by multipart uploads. Must be between 5M (S3 minimum) and
# 5G (S3 maximum); the last part may be smaller. Defaults to "5M". Pick a
# larger value (16M-64M) on high-bandwidth links to amortize per-request
# overhead. The S3 service caps a multipart upload at 10000 parts, so the
# largest single object you can upload is part-size * 10000 (e.g. 16M parts
# allow up to 160 GiB, 64M parts allow up to 640 GiB).
# multipart-part-size = "16M"

# Total attempts (initial + retries) the AWS SDK makes on transient failures
# (HTTP 5xx, request timeouts, throttling, connection errors). 1 disables
# retries; 4xx client errors fail immediately regardless of this value.
# retry-max-attempts = 3

# Console log output format. "text" (default) writes single-line, human-
# readable output; "json" writes one UTF-8 JSON object per line with UTC
# timestamps for log shippers such as Datadog or Loki.
# log-format = "text"

# DANGER: skip the bucket-versioning safety check. Local edits and deletes
# become unrecoverable. Intended for CI / disposable buckets only.
# allow-unversioned = false

# Raise log verbosity to Debug.
# verbose = false
